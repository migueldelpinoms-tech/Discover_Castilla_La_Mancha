<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#b50c1b"
    tools:context=".menuProvincias">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnToledo"
        android:layout_width="306dp"
        android:layout_height="59dp"
        android:layout_gravity="center"
        android:layout_margin="8dp"
        android:background="#d0b700"
        android:text="Toledo"
        android:fontFamily="@font/basteleur_bold"
        android:textColor="@color/black"
        android:textSize="18dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.437" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCiudadReal"
        android:layout_width="306dp"
        android:layout_height="59dp"
        android:layout_gravity="center"
        android:layout_margin="8dp"
        android:background="#d0b700"
        android:text="Ciudad Real"
        android:fontFamily="@font/basteleur_bold"
        android:textColor="@color/black"
        android:textSize="18dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.559" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGuadalajara"
        android:layout_width="306dp"
        android:layout_height="59dp"
