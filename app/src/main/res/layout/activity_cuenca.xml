<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Provincias.Cuenca"
    android:background="#b50c1b">

    <TextView
        android:layout_width="363dp"
        android:layout_height="64dp"
        android:layout_marginTop="168dp"
        android:text="Casas colgadas, paisajes de otro mundo y misterio en cada calle. ¡Ven a enamorarte de Cuenca!"
        android:textColor="@color/black"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:maxLines="3"
        android:fontFamily="@font/basteleur_bold"
        android:textSize="16dp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.458"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnInfoC"
        android:contentDescription="Información"
        android:layout_width="124dp"
        android:layout_height="134dp"
        android:background="@drawable/cuadrosinfondo"
        android:padding="5dp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.153"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.388"
        app:srcCompat="@mipmap/guiasinfondo" />

    <ImageButton
        android:id="@+id/btnPatrimonioC"
